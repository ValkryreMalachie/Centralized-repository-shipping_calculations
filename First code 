      "source": [
        "students = []\n",
        "\n",
        "while True: # Capital T!\n",
        "    name = await input(\"Enter name: \")\n",
        "    age = await input(\"Enter age: \")\n",
        "    grade = await input(\"Enter grade: \")\n",
        "\n",
        "    student_info = {\n",
        "        \"name\": name,\n",
        "        \"age\": age,\n",
        "        \"grade\": grade\n",
        "    }\n",
        "\n",
        "    # (Ghost brace deleted)\n",
        "\n",
        "    students.append(student_info)\n",
        "    print(f\"Added {name} to the list!\") # Added 'f' and fixed quotes\n",
        "\n",
        "    cont = await input(\"Add another student? (yes/no): \")\n",
        "    if cont.lower() == \"no\":\n",
        "        break\n",
        "\n",
        "print(\"\\nFinal Student List:\")\n",
        "print(students)\n",
        "\n",
        "\n",
        "\n"
